# Normalize line endings to LF in the repo on all platforms.
# This overrides core.autocrlf and stops the "LF will be replaced by CRLF" warning.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary files — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary
